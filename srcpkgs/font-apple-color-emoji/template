# Template file for 'font-apple-color-emoji'
pkgname=font-apple-color-emoji
version=20260613
revision=1
_tag="macos-26-${version}-f1fc560b"
depends="font-util"
short_desc="Apple Color Emoji font for Linux"
maintainer="al20ov <nicolas.antauf@gmail.com>"
license="custom:Apple-Proprietary"
homepage="https://github.com/samuelngs/apple-emoji-ttf"
distfiles="https://github.com/samuelngs/apple-emoji-ttf/releases/download/${_tag}/AppleColorEmoji-Linux.ttf"
