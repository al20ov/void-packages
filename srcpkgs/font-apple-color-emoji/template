font_dirs="/usr/share/fonts/TTF/emoji"
provides="font:emoji-0_1"

do_extract() {
	install -Dm644 ${XBPS_SRCDISTDIR}/${pkgname}-${version}/AppleColorEmoji-Linux.ttf \
		${wrksrc}/AppleColorEmoji-Linux.ttf
}

do_install() {
	vinstall AppleColorEmoji-Linux.ttf 644 usr/share/fonts/TTF/emoji
}
