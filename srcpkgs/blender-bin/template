# Template file for 'blender-bin'
pkgname=blender-bin
version=5.1.0
revision=1
archs="x86_64"
depends="desktop-file-utils hicolor-icon-theme libX11 libXfixes libXi libXrender
 libxkbcommon vulkan-loader"
short_desc="3D graphics creation suite (upstream binary)"
maintainer="Orphaned <orphan@voidlinux.org>"
license="GPL-3.0-or-later"
homepage="https://www.blender.org"
distfiles="https://download.blender.org/release/Blender${version%.*}/blender-${version}-linux-x64.tar.xz"
checksum="7f2475990613c8d4c7ac5697803fcf40d09541c1fd8c23936f4b07a169a920c7"
conflicts="blender"
nostrip=yes
nopie=yes
noshlibprovides=yes
noverifyrdeps=yes
python_version=ignore # Avoid 03-rewrite-python-shebang errors

do_install() {
	# Install everything under /opt/blender so that the binary resolves against
	# bundled .so.
	vmkdir opt/blender
	vcopy . opt/blender

	# Symlinks
	vmkdir usr/bin
	ln -sf /opt/blender/blender ${PKGDESTDIR}/usr/bin/blender
	ln -sf /opt/blender/blender-thumbnailer ${PKGDESTDIR}/usr/bin/blender-thumbnailer

	vinstall blender.desktop 644 usr/share/applications
	vinstall blender.svg 644 usr/share/icons/hicolor/scalable/apps
	vinstall blender-symbolic.svg 644 usr/share/icons/hicolor/symbolic/apps
}
