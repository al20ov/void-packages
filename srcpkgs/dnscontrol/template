# Template file for 'dnscontrol'
pkgname=dnscontrol
version=4.36.1
revision=1
build_style=go
build_helper=qemu
go_import_path=github.com/StackExchange/dnscontrol/v4
short_desc="Opinionated platform for managing DNS configuration"
maintainer="al20ov <nicolas.antauf@gmail.com>"
license="MIT"
homepage="https://dnscontrol.org"
distfiles="https://github.com/StackExchange/dnscontrol/archive/refs/tags/v${version}.tar.gz"
checksum="2584fe62ac4f6895a4780ac82c2abc3a516638d650f51f8376c801694a5c2b03"

post_install() {
	vlicense LICENSE

	# Shell completion files are generated by the compiled binary from a Go
	# template file
	for _shell in bash zsh; do
		vtargetrun ${DESTDIR}/usr/bin/dnscontrol shell-completion ${_shell} > dnscontrol.${_shell}
		vcompletion dnscontrol.${_shell} ${_shell}
	done
}
