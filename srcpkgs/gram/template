# }

do_install() {
	vbin "target/${RUST_TARGET}/release/cli" gram-cli
	vinstall "target/${RUST_TARGET}/release/gram" 755 usr/libexec gram-editor

	export APP_NAME="Gram"
	export APP_CLI="gram-cli"
	export APP_ICON="gram"
	export APP_ARGS="%U"
	export DO_STARTUP_NOTIFY="true"

	envsubst < "crates/gram/resources/gram.desktop.in" > "app.liten.Gram.desktop"
	vinstall "app.liten.Gram.desktop" 644 usr/share/applications

	vinstall "crates/gram/resources/app-icon.png" 644 usr/share/icons/hicolor/512x512/apps gram.png
	vinstall "crates/gram/resources/app-icon@2x.png" 644 usr/share/icons/hicolor/1024x1024/apps gram.png
}
